# =============================================================================
# Production Environment Configuration (Example)
# =============================================================================
# This file is a template for production.
# Copy to .env.prod and fill with real values.
# DO NOT commit real secrets to the repository!
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Production environment — gin release mode, minimal logging.
APP_ENV=prod

# Production server port.
# Recommended to use port > 1024 or set up a reverse proxy.
APP_PORT=8080

APP_NAME=skeleton

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite database file path. Ensure the directory exists and has write permissions.
# For production, consider migrating to PostgreSQL as load increases.
DB_PATH=./data/skeleton.db

# SQLite — always 1.
DB_MAX_OPEN_CONNS=1

# ── Authentication (JWT RS256) ───────────────────────────────────────────────
# RSA keys must be generated separately and protected from reading.
# Recommended permissions: chmod 600 keys/*.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Access token — short (15-30 min) to minimize risk if compromised.
JWT_ACCESS_TTL_MINUTES=15

# Refresh token — longer (7-30 days) for user convenience.
JWT_REFRESH_TTL_DAYS=7

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis is used for event bus and session store in production.
# Format: redis://[password@]host:port/db
# For cluster: redis+cluster://host1:port1,host2:port2/db
REDIS_URL=redis://localhost:6379/0

# ── Sessions (cookie-based, for web) ──────────────────────────────────────────
# In production, sessions are stored in Redis — fast, with TTL, can be terminated.
# Cookie contains only session ID (HttpOnly, Secure, SameSite=Strict).
SESSION_COOKIE_NAME=session
SESSION_COOKIE_DOMAIN=.yourdomain.com
SESSION_COOKIE_SECURE=true
SESSION_TTL_MINUTES=1440

# ── Logging ───────────────────────────────────────────────────────────────────
# Info level — balance between visibility and log volume.
# For troubleshooting, temporarily change to debug.
LOG_LEVEL=info

# JSON format — for integration with ELK, Datadog, CloudWatch, etc.
LOG_FORMAT=json

# ── Caching ───────────────────────────────────────────────────────────────────
# Production — redis for distributed caching across all instances.
CACHE_TYPE=redis

# Default TTL (seconds). Adjust based on your data access patterns.
CACHE_DEFAULT_TTL=300

# Redis key prefix — prevent collisions if Redis is shared.
CACHE_REDIS_PREFIX=skeleton_prod

# Not used with Redis (Redis handles TTL automatically).
CACHE_CLEANUP_INTERVAL=60

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Production — always enable rate limiting.
RATE_LIMIT_ENABLED=true

# Production — sliding_window for accurate distributed rate limiting.
RATE_LIMIT_TYPE=sliding_window

# Redis key prefix.
RATE_LIMIT_KEY_PREFIX=ratelimit_prod

# Global rate limit (all endpoints combined).
# Adjust based on your server capacity and expected load.
RATE_LIMIT_GLOBAL_LIMIT=1000
RATE_LIMIT_GLOBAL_WINDOW=60

# Authentication — stricter limits to prevent brute force.
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_AUTH_WINDOW=60

# File operations — prevent storage abuse.
RATE_LIMIT_FILES_LIMIT=10
RATE_LIMIT_FILES_WINDOW=60