# =============================================================================
# Production Environment Configuration (Template)
# =============================================================================
# This file is a template for production.
# Copy to .env.prod and fill with real values.
# DO NOT commit real secrets to the repository!
#
# IMPORTANT: Set DATABASE_URL and REDIS_URL via environment variables!
# Example: export DATABASE_URL=postgres://user:pass@host:5432/db
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=prod
APP_PORT=8080
APP_NAME=skeleton

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
# IMPORTANT: Set DATABASE_URL via environment variable in production!
# Example: postgres://user:password@prod-host:5432/skeleton?sslmode=require
DATABASE_URL=${DATABASE_URL}
DATABASE_TYPE=postgres

# Connection pool settings for production.
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=10m
DB_CONN_MAX_IDLE_TIME=5m

# ── Authentication (JWT RS256) ──────────────────────────────────────────────
# RSA keys must be generated separately and protected from reading.
# Recommended permissions: chmod 600 keys/*.pem
# In production: mount from secrets (Kubernetes secrets, AWS Secrets Manager, etc.)
JWT_PRIVATE_KEY_PATH=/secrets/private.pem
JWT_PUBLIC_KEY_PATH=/secrets/public.pem

# Access token — short (15-30 min) to minimize risk if compromised.
JWT_ACCESS_TTL=15m

# Refresh token — longer (7-30 days) for user convenience.
JWT_REFRESH_TTL=168h

# NEVER use mock tokens in production!
USE_MOCK_TOKENS=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Set REDIS_URL via environment variable in production!
# Format: redis://[password@]host:port/db
# For cluster: redis+cluster://host1:port1,host2:port2/db
REDIS_URL=${REDIS_URL}

# ── Sessions (cookie-based, for web) ─────────────────────────────────────────
# In production, sessions are stored in Redis.
SESSION_COOKIE_NAME=session
SESSION_COOKIE_DOMAIN=.yourdomain.com
SESSION_COOKIE_SECURE=true
SESSION_TTL_MINUTES=1440

# ── Logging ───────────────────────────────────────────────────────────────────
# Info level — balance between visibility and log volume.
LOG_LEVEL=info

# JSON format — for integration with ELK, Datadog, CloudWatch, etc.
LOG_FORMAT=json

# ── Caching ───────────────────────────────────────────────────────────────────
# Production — Redis for distributed caching across all instances.
CACHE_TYPE=redis
CACHE_DEFAULT_TTL=300
CACHE_REDIS_PREFIX=skeleton_prod

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Production — ALWAYS enable rate limiting.
RATE_LIMIT_ENABLED=true

# Production — sliding_window for accurate distributed rate limiting.
RATE_LIMIT_TYPE=sliding_window
RATE_LIMIT_KEY_PREFIX=ratelimit_prod

# Global rate limit (all endpoints combined).
# Adjust based on your server capacity and expected load.
RATE_LIMIT_GLOBAL_LIMIT=10000
RATE_LIMIT_GLOBAL_WINDOW=60

# Authentication — stricter limits to prevent brute force.
RATE_LIMIT_AUTH_LIMIT=10
RATE_LIMIT_AUTH_WINDOW=60

# File operations — prevent storage abuse.
RATE_LIMIT_FILES_LIMIT=50
RATE_LIMIT_FILES_WINDOW=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Set allowed origins via environment variable!
# Example: https://app.yourdomain.com,https://api.yourdomain.com
CORS_ALLOWED_ORIGINS=${ALLOWED_ORIGINS}
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ── File Upload ───────────────────────────────────────────────────────────────
# Maximum file upload size in bytes (default: 100MB).
MAX_UPLOAD_SIZE=104857600

# ── Production Checklist ─────────────────────────────────────────────────────
# ✅ Set DATABASE_URL from secrets
# ✅ Set REDIS_URL from secrets
# ✅ Set CORS_ALLOWED_ORIGINS
# ✅ Generate JWT keys: make keys
# ✅ Set USE_MOCK_TOKENS=false
# ✅ Use HTTPS/TLS
# ✅ Configure firewall rules
# ✅ Set up monitoring and alerts
# ✅ Configure backup strategy