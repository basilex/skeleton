# =============================================================================
# Production Environment Configuration (Example)
# =============================================================================
# Цей файл — шаблон для production.
# Скопіюйте в .env.prod і заповніть реальними значеннями.
# НЕ комітьте реальні секрети в репозиторій!
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Production оточення — gin режим release, мінімальне логування.
APP_ENV=prod

# Порт для продакшн сервера.
# Рекомендується використовувати порт > 1024 або налаштувати reverse proxy.
APP_PORT=8080

APP_NAME=skeleton

# ── Database ──────────────────────────────────────────────────────────────────
# Шлях до SQLite файлу. Переконайтесь що директорія існує і має права запису.
# Для production розглядіть міграцію на PostgreSQL при зростанні навантаження.
DB_PATH=./data/skeleton.db

# SQLite — завжди 1.
DB_MAX_OPEN_CONNS=1

# ── Authentication (JWT RS256) ───────────────────────────────────────────────
# RSA ключі мають бути згенеровані окремо і захищені від читання.
# Рекомендовані права: chmod 600 keys/*.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Access token — короткий (15-30 хв) для мінімізації ризику при компрометації.
JWT_ACCESS_TTL_MINUTES=15

# Refresh token — довший (7-30 днів) для зручності користувачів.
JWT_REFRESH_TTL_DAYS=7

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis використовується для event bus та session store у production.
# Format: redis://[password@]host:port/db
# Для кластера: redis+cluster://host1:port1,host2:port2/db
REDIS_URL=redis://localhost:6379/0

# ── Sessions (cookie-based, для web) ──────────────────────────────────────────
# У production сесії зберігаються у Redis — швидкі, з TTL, можна завершити.
# Cookie містить тільки session ID (HttpOnly, Secure, SameSite=Strict).
SESSION_COOKIE_NAME=session
SESSION_COOKIE_DOMAIN=.yourdomain.com
SESSION_COOKIE_SECURE=true
SESSION_TTL_MINUTES=1440

# ── Logging ───────────────────────────────────────────────────────────────────
# Info рівень — баланс між видимістю та об'ємом логів.
# Для troubleshooting тимчасово змініть на debug.
LOG_LEVEL=info

# JSON формат — для інтеграції з ELK, Datadog, CloudWatch тощо.
LOG_FORMAT=json
