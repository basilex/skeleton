# =============================================================================
# Environment Configuration Template
# =============================================================================
# Скопіюйте цей файл як .env.dev для локальної розробки:
#   cp configs/.env.example configs/.env.dev
#
# Або задайте APP_ENV=test/prod і відповідний .env.{env} завантажиться
# автоматично при старті додатку.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Оточення: dev | test | prod. Визначає який .env.{env} файл завантажувати.
APP_ENV=dev

# Порт HTTP сервера.
APP_PORT=8080

# Ім'я додатку (використовується в логах, метриках).
APP_NAME=skeleton

# ── Database ──────────────────────────────────────────────────────────────────
# Шлях до SQLite файлу. Для in-memory використовуйте ":memory:".
# Директорія ./data/ створюється автоматично при старті.
DB_PATH=./data/skeleton.db

# Максимальна кількість відкритих з'єднань.
# Для SQLite завжди 1 — драйвер не підтримує конкурентний запис.
DB_MAX_OPEN_CONNS=1

# ── Authentication (JWT RS256) ───────────────────────────────────────────────
# Шляхи до RSA ключів. Генерація: make keys
# Приватний ключ — для підпису токенів, публічний — для верифікації.
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Час життя access токену (хвилини). Рекомендовано: 15-30.
JWT_ACCESS_TTL_MINUTES=15

# Час життя refresh токену (дні). Рекомендовано: 7-30.
JWT_REFRESH_TTL_DAYS=7

# ── Redis ─────────────────────────────────────────────────────────────────────
# URL для Redis Pub/Sub (event bus). Використовується тільки в prod.
# У dev/test — in-memory event bus (синхронний, без залежностей).
REDIS_URL=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────
# Рівень логування: debug | info | warn | error.
LOG_LEVEL=debug

# Формат логів: text (читабельний) | json (для агрегації).
LOG_FORMAT=text
