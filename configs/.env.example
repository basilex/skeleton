# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file as .env.dev for local development:
#   cp configs/.env.example configs/.env.dev
#
# Or set APP_ENV=test/prod and the corresponding .env.{env} file will be loaded
# automatically when the application starts.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Environment: dev | test | prod. Determines which .env.{env} file to load.
APP_ENV=dev

# HTTP server port.
APP_PORT=8080

# Application name (used in logs, metrics).
APP_NAME=skeleton

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite database file path. Use ":memory:" for in-memory database.
# The ./data/ directory is created automatically on startup.
DB_PATH=./data/skeleton.db

# Maximum number of open connections.
# For SQLite always 1 — driver doesn't support concurrent writes.
DB_MAX_OPEN_CONNS=1

# ── Authentication (JWT RS256) ───────────────────────────────────────────────
# RSA key paths. Generate with: make keys
# Private key — for signing tokens, public key — for verification.
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Access token lifetime (minutes). Recommended: 15-30.
JWT_ACCESS_TTL_MINUTES=15

# Refresh token lifetime (days). Recommended: 7-30.
JWT_REFRESH_TTL_DAYS=7

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis URL for Pub/Sub (event bus). Used only in prod.
# In dev/test — in-memory event bus (synchronous, no dependencies).
REDIS_URL=redis://localhost:6379/0

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error.
LOG_LEVEL=debug

# Log format: text (readable) | json (for aggregation).
LOG_FORMAT=text