# Application
APP_ENV=development
APP_PORT=8080

# Database
DATABASE_URL=postgres://skeleton:skeleton@localhost:5432/skeleton?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Session
SESSION_SECRET=your-secret-key-min-32-characters-change-in-production
SESSION_TTL=168h

# JWT
JWT_SECRET=your-jwt-secret-key-min-32-characters-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# CORS (optional)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=debug

# Email (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@example.com

# Storage (optional)
# STORAGE_TYPE=local
# STORAGE_PATH=./uploads

# AWS S3 (optional)
# AWS_S3_BUCKET=your-bucket
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
