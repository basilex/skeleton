# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file as .env.dev for local development:
#   cp configs/.env.example configs/.env.dev
#
# Or set APP_ENV=test/prod and the corresponding .env.{env} file will be loaded
# automatically when the application starts.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Environment: dev | test | prod. Determines which .env.{env} file to load.
APP_ENV=dev

# HTTP server port.
APP_PORT=8080

# Application name (used in logs, metrics).
APP_NAME=skeleton

# ── Database (PostgreSQL) ────────────────────────────────────────--------------
# PostgreSQL connection URL
# Format: postgres://user:password@host:port/database?options
DATABASE_URL=postgres://skeleton:password@localhost:5432/skeleton?sslmode=disable

# Database type (always "postgres" for this project)
DATABASE_TYPE=postgres

# Connection pool settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=30m
DB_HEALTH_CHECK=1m

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# ── Authentication (JWT RS256) ───────────────────────────────────────────────
# RSA private/public key file paths (generated with `make keys`)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Access token TTL (default: 15 minutes)
JWT_ACCESS_TTL=15m

# Refresh token TTL (default: 7 days)
JWT_REFRESH_TTL=168h

# ── Mock Token Service (Development Only) ───────────────────────────────────
# Set to "true" in dev/test to use mock tokens instead of JWT
# WARNING: Never use mock tokens in production!
USE_MOCK_TOKENS=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Rate limit type: token_bucket | sliding_window
RATE_LIMIT_TYPE=sliding_window

# Global rate limits
RATE_LIMIT_GLOBAL_LIMIT=1000
RATE_LIMIT_GLOBAL_WINDOW=60

# Auth rate limits (login, register)
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_AUTH_WINDOW=60

# ── Cache ─────────────────────────────────────────────────────────────────────
# Cache type: memory | redis
CACHE_TYPE=redis

# Cache TTL (default: 5 minutes)
CACHE_DEFAULT_TTL=300

# ── File Upload ───────────────────────────────────────────────────────────────
# Maximum file upload size in bytes (default: 100MB)
MAX_UPLOAD_SIZE=104857600

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=debug

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Allowed methods (comma-separated)
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Allowed headers (comma-separated)
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ── Development Mode Settings ─────────────────────────────────────────────────
# When APP_ENV=dev:
# - Mock tokens are used instead of JWT
# - Detailed error responses
# - CORS allows all origins
# - Log level is debug

# ── Production Mode Settings ──────────────────────────────────────────────────
# When APP_ENV=prod:
# - JWT tokens are required
# - Minimal error responses
# - CORS respects ALLOWED_ORIGINS
# - Log level is info or warn
# - Rate limiting enforced