# =============================================================================
# Development Environment Configuration
# =============================================================================
# This file is loaded automatically when APP_ENV=dev (default).
# Copy from configs/.env.example if customization is needed.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Environment: dev | test | prod. Determines which .env.{env} file to load.
APP_ENV=dev

# HTTP server port.
APP_PORT=8080

# Application name (used in logs, metrics).
APP_NAME=skeleton

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
# PostgreSQL connection URL for development.
# Uses Docker Compose PostgreSQL service (see docker-compose.yml).
DATABASE_URL=postgres://skeleton:skeleton@localhost:5432/skeleton?sslmode=disable

# Database type: always "postgres" for this project.
DATABASE_TYPE=postgres

# Connection pool settings for development.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m

# ── Authentication (JWT RS256) ──────────────────────────────────────────────
# RSA private/public key file paths (generated with `make keys`).
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Access token TTL (default: 15 minutes).
JWT_ACCESS_TTL=15m

# Refresh token TTL (default: 7 days).
JWT_REFRESH_TTL=168h

# Use mock tokens in development for easier testing.
# WARNING: Never use mock tokens in production!
USE_MOCK_TOKENS=true

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis URL for event bus, sessions, and distributed caching.
# Uses Docker Compose Redis service (see docker-compose.yml).
REDIS_URL=redis://localhost:6379/0

# ── Sessions (cookie-based, for web) ─────────────────────────────────────────
# Sessions are stored in Redis (prod) or in-memory (dev/test).
SESSION_COOKIE_NAME=session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_TTL_MINUTES=1440

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error.
LOG_LEVEL=debug

# Log format: text (readable) | json (for aggregation).
LOG_FORMAT=text

# ── Caching ───────────────────────────────────────────────────────────────────
# Cache type: memory (local) | redis (distributed).
CACHE_TYPE=memory

# Default TTL for cached items (seconds).
CACHE_DEFAULT_TTL=300

# Key prefix for Redis (to avoid collisions).
CACHE_REDIS_PREFIX=skeleton

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Enable/disable rate limiting for API protection.
RATE_LIMIT_ENABLED=true

# Rate limiter type: token_bucket (local) | sliding_window (distributed).
RATE_LIMIT_TYPE=token_bucket

# Key prefix for Redis (to avoid collisions).
RATE_LIMIT_KEY_PREFIX=ratelimit

# Global API rate limits (all endpoints).
RATE_LIMIT_GLOBAL_LIMIT=1000
RATE_LIMIT_GLOBAL_WINDOW=60

# Authentication endpoints (login, register, password reset).
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_AUTH_WINDOW=60

# File operations (upload, download, process).
RATE_LIMIT_FILES_LIMIT=10
RATE_LIMIT_FILES_WINDOW=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origins (comma-separated).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Allowed methods (comma-separated).
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Allowed headers (comma-separated).
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ── File Upload ───────────────────────────────────────────────────────────────
# Maximum file upload size in bytes (default: 100MB).
MAX_UPLOAD_SIZE=104857600

# ── Development Mode Settings ─────────────────────────────────────────────────
# When APP_ENV=dev:
# - Mock tokens are used instead of JWT (simpler testing)
# - Detailed error responses
# - CORS allows all origins
# - Log level is debug
# - In-memory event bus (no external dependencies)
# - PostgreSQL via Docker Compose (make docker-up)